<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.foro.PruebaAptitudFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvwTituloPrueba"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_prueba_aptitud"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvwInstruccionesPrueba"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/instrucciones_prueba"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwTituloPrueba" />

        <!-- Pregunta 1 -->
        <TextView
            android:id="@+id/tvwPregunta1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_1"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvwInstruccionesPrueba" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRespuesta1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwPregunta1">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespuesta1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:hint="@string/hint_respuesta"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 2 -->
        <TextView
            android:id="@+id/tvwPregunta2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_2"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tilRespuesta1" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRespuesta2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwPregunta2">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespuesta2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:hint="@string/hint_respuesta"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 3 -->
        <TextView
            android:id="@+id/tvwPregunta3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_3"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tilRespuesta2" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRespuesta3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwPregunta3">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespuesta3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:hint="@string/hint_respuesta"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 4 -->
        <TextView
            android:id="@+id/tvwPregunta4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_4"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tilRespuesta3" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRespuesta4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwPregunta4">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespuesta4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:hint="@string/hint_respuesta"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Pregunta 5 -->
        <TextView
            android:id="@+id/tvwPregunta5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_5"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tilRespuesta4" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRespuesta5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvwPregunta5">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRespuesta5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top"
                android:hint="@string/hint_respuesta"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvwErrorValidacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/tilRespuesta5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnviarPrueba"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_enviar_prueba"
            app:layout_constraintTop_toBottomOf="@id/tvwErrorValidacion" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>